[submodule "corfu"]
	load-path = .
	load-path = extensions
[submodule "dirvish"]
	load-path = .
	load-path = extensions
[submodule "org-mem"]
	# デフォルト値と同じだが意図的に明示している。borg-load-path の
	# フォールバックは lisp/ ディレクトリが存在するとそれ「だけ」を
	# load-path にする。org-mem はかつて lisp/ を同梱しており、その頃の
	# 残骸（未追跡ファイル）が worktree に残っているマシンでは、明示が
	# ないとルートの org-mem.el が load-path から外れてビルドが壊れる。
	# 全マシンで lib/org-mem/lisp/ が存在しないことを確認できたら、
	# このセクションごと削除してよい。
	load-path = .
[submodule "org-node"]
	no-maketexi = README.org
[submodule "org-roam"]
	load-path = .
	load-path = extensions
[submodule "emacsql"]
	no-byte-compile = emacsql-pg.el
[submodule "hydra"]
	no-byte-compile = hydra-examples.el
[submodule "restclient"]
	no-byte-compile = restclient-helm.el
[submodule "vertico"]
	load-path = .
	load-path = extensions
[submodule "ghostel"]
	build-step = borg-update-autoloads
	build-step = borg-compile
	build-step = borg-maketexi
	build-step = borg-makeinfo
	build-step = (progn (require 'ghostel-module-install) (ghostel--download-module (ghostel--module-directory) nil t))
[submodule "vterm"]
	build-step = borg-update-autoloads
	build-step = borg-compile
	build-step = (progn (setq vterm-always-compile-module t) (require 'vterm) (vterm-module-compile))
[submodule "wgrep"]
	no-byte-compile = wgrep-ack.el
	no-byte-compile = wgrep-deadgrep.el
	no-byte-compile = wgrep-helm.el
	no-byte-compile = wgrep-pt.el
	no-byte-compile = wgrep-subtest.el
	no-byte-compile = wgrep-test-helper.el
	no-byte-compile = wgrep-test.el
